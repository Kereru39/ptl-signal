---
// NewsletterSignup.astro
// Uses the real MailerLite embed structure — their JS handles submission.
// variant: 'homepage' | 'blog' | 'footer'
interface Props {
  variant?: 'homepage' | 'blog' | 'footer';
}
const { variant = 'blog' } = Astro.props;
---

{variant === 'homepage' && (
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="relative bg-navy-light border border-accent/20 rounded-2xl p-10 md:p-14 overflow-hidden text-center">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-64 bg-accent/8 rounded-full blur-3xl pointer-events-none"></div>
      <div class="relative">
        <span class="font-mono text-accent text-sm">// newsletter</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-3">Get the Signal. Skip the Noise.</h2>
        <p class="text-gray-400 mb-8 text-lg">Weekly AI, Bitcoin &amp; market analysis from Lisa Tamati. Free.</p>
        <div class="max-w-md mx-auto">
          <div id="mlb2-39387468" class="ml-subscribe-form ml-subscribe-form-39387468">
            <div class="row-form">
              <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/80279/forms/183689354553591350/subscribe" data-code="" method="post" target="_blank">
                <div class="ml-field-email-wrap flex flex-col sm:flex-row gap-3">
                  <input
                    aria-label="email"
                    type="email"
                    name="fields[email]"
                    class="form-control ml-email-input flex-1"
                    placeholder="Your email address"
                    autocomplete="email"
                    required
                  />
                  <input type="hidden" name="ml-submit" value="1" />
                  <input type="hidden" name="anticsrf" value="true" />
                  <button type="submit" class="ml-submit-btn">Subscribe</button>
                  <button disabled type="button" class="ml-loading-btn" style="display:none">Subscribing…</button>
                </div>
              </form>
            </div>
            <div class="row-success" style="display:none">
              <p class="text-accent font-mono text-sm mt-4">You're in. Check your inbox. ✓</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'blog' && (
  <div class="mt-12 bg-navy-light border border-accent/20 rounded-2xl p-8 md:p-10">
    <p class="font-mono text-accent text-xs mb-2">// newsletter</p>
    <p class="text-white text-xl font-bold mb-1">Want more like this?</p>
    <p class="text-gray-400 text-sm mb-6">Join the PTL Signal newsletter. Weekly AI, Bitcoin &amp; market analysis from Lisa Tamati.</p>
    <div id="mlb2-39387468" class="ml-subscribe-form ml-subscribe-form-39387468">
      <div class="row-form">
        <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/80279/forms/183689354553591350/subscribe" data-code="" method="post" target="_blank">
          <div class="ml-field-email-wrap flex flex-col sm:flex-row gap-3 max-w-sm">
            <input
              aria-label="email"
              type="email"
              name="fields[email]"
              class="form-control ml-email-input flex-1"
              placeholder="Your email address"
              autocomplete="email"
              required
            />
            <input type="hidden" name="ml-submit" value="1" />
            <input type="hidden" name="anticsrf" value="true" />
            <button type="submit" class="ml-submit-btn">Subscribe</button>
            <button disabled type="button" class="ml-loading-btn" style="display:none">Subscribing…</button>
          </div>
        </form>
      </div>
      <div class="row-success" style="display:none">
        <p class="text-accent font-mono text-sm mt-4">You're in. Check your inbox. ✓</p>
      </div>
    </div>
  </div>
)}

{variant === 'footer' && (
  <div class="border-t border-white/10 mt-20 bg-navy-light">
    <div class="max-w-6xl mx-auto px-4 py-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-6">
        <p class="text-gray-300 text-sm font-medium whitespace-nowrap">Join the PTL Signal newsletter</p>
        <div id="mlb2-39387468" class="ml-subscribe-form ml-subscribe-form-39387468 flex-1">
          <div class="row-form">
            <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/80279/forms/183689354553591350/subscribe" data-code="" method="post" target="_blank">
              <div class="ml-field-email-wrap flex gap-3 max-w-md">
                <input
                  aria-label="email"
                  type="email"
                  name="fields[email]"
                  class="form-control ml-email-input flex-1"
                  placeholder="Your email address"
                  autocomplete="email"
                  required
                />
                <input type="hidden" name="ml-submit" value="1" />
                <input type="hidden" name="anticsrf" value="true" />
                <button type="submit" class="ml-submit-btn ml-submit-btn-sm">Subscribe</button>
                <button disabled type="button" class="ml-loading-btn ml-submit-btn-sm" style="display:none">Subscribing…</button>
              </div>
            </form>
          </div>
          <div class="row-success" style="display:none">
            <p class="text-accent font-mono text-xs mt-2">You're in. Check your inbox. ✓</p>
          </div>
        </div>
      </div>
    </div>
  </div>
)}

<!-- MailerLite scripts — loaded once per page via the _mlLoaded guard -->
<script is:inline>
  (function() {
    if (window._mlFormsLoaded) return;
    window._mlFormsLoaded = true;

    // Success callback MailerLite's JS will call after successful submission
    window.ml_webform_success_39387468 = function() {
      document.querySelectorAll('.ml-subscribe-form-39387468 .row-form').forEach(function(el) {
        el.style.display = 'none';
      });
      document.querySelectorAll('.ml-subscribe-form-39387468 .row-success').forEach(function(el) {
        el.style.display = 'block';
      });
    };

    // Load MailerLite webforms JS
    var s = document.createElement('script');
    s.src = 'https://groot.mailerlite.com/js/w/webforms.min.js?v95037e5bac78f29ed026832ca21a7c7b';
    s.type = 'text/javascript';
    document.head.appendChild(s);

    // Required takel fetch
    fetch('https://assets.mailerlite.com/jsonp/80279/forms/183689354553591350/takel');
  })();
</script>

<style is:global>
  /* Dark theme overrides for MailerLite form elements */
  .ml-email-input {
    background: #0a0f1e;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    color: #d1d5db;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }
  .ml-email-input::placeholder {
    color: #6b7280;
  }
  .ml-email-input:focus {
    border-color: rgba(0, 212, 170, 0.5);
  }
  .ml-submit-btn {
    background: #00d4aa;
    color: #0a0f1e;
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    font-size: 0.875rem;
    transition: background 0.2s;
  }
  .ml-submit-btn:hover {
    background: #00b894;
  }
  .ml-submit-btn-sm {
    padding: 0.625rem 1.25rem;
  }
  .ml-loading-btn {
    background: #00d4aa;
    color: #0a0f1e;
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    border: none;
    white-space: nowrap;
    font-size: 0.875rem;
    opacity: 0.7;
    cursor: not-allowed;
  }
  /* Hide any default MailerLite styles that might bleed through */
  .ml-subscribe-form .ml-block-form { margin: 0; }
  .ml-subscribe-form input.form-control { box-shadow: none; }
</style>
