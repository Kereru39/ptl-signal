---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  tag: string;
  slug: string;
  image?: string;
}

const { title, excerpt, date, tag, slug, image } = Astro.props;
---

<a href={`/blog/${slug}`} class="block bg-navy-light border border-white/10 rounded-xl overflow-hidden hover:border-accent/30 transition-colors group">
  {image && (
    <div class="aspect-video overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    </div>
  )}
  <div class="p-6">
    <div class="flex items-center gap-3 mb-3">
      <span class="font-mono text-xs px-2 py-1 bg-accent/10 text-accent rounded">{tag}</span>
      <span class="text-xs text-gray-400">{date}</span>
    </div>
    <h3 class="text-lg font-semibold group-hover:text-accent transition-colors">{title}</h3>
    <p class="text-gray-400 text-sm mt-2 line-clamp-3">{excerpt}</p>
    <span class="inline-block mt-4 text-accent text-sm font-mono">Read more &rarr;</span>
  </div>
</a>
