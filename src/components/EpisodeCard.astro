---
interface Props {
  title: string;
  videoId: string;
  description: string;
  date: string;
}

const { title, videoId, description, date } = Astro.props;
---

<div class="bg-navy-light border border-white/10 rounded-xl overflow-hidden hover:border-accent/30 transition-colors group">
  <div class="aspect-video">
    <iframe
      src={`https://www.youtube.com/embed/${videoId}`}
      title={title}
      class="w-full h-full"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
  <div class="p-5">
    <span class="font-mono text-xs text-accent">{date}</span>
    <h3 class="text-lg font-semibold mt-1 group-hover:text-accent transition-colors">{title}</h3>
    <p class="text-gray-400 text-sm mt-2 line-clamp-2">{description}</p>
  </div>
</div>
