---
import NewsletterSignup from './NewsletterSignup.astro';
---

<NewsletterSignup variant="footer" />
<footer class="border-t border-white/10">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <span class="font-mono font-bold text-lg">
          <span class="text-accent">PTL</span> Signal
        </span>
        <p class="text-gray-400 text-sm mt-2">Cutting through the noise — AI, markets, and the signals that matter.</p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-mono text-accent text-xs mb-3">// links</h4>
        <div class="space-y-2 text-sm">
          <a href="https://lisatamati.com" target="_blank" class="block text-gray-300 hover:text-accent transition-colors">
            Health & Longevity: lisatamati.com
          </a>
          <a href="https://shop.lisatamati.com" target="_blank" class="block text-gray-300 hover:text-accent transition-colors">
            Supplement Store
          </a>
          <a href="https://earningscallanalyzer.com" target="_blank" class="block text-gray-300 hover:text-accent transition-colors">
            Earnings Call Analyzer
          </a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-mono text-accent text-xs mb-3">// contact</h4>
        <a href="mailto:lisa@lisatamati.com" class="text-sm text-gray-300 hover:text-accent transition-colors">
          lisa@lisatamati.com
        </a>
      </div>
    </div>

    <div class="text-center text-gray-400 text-xs mt-10 pt-6 border-t border-white/5">
      &copy; 2026 Lisa Tamati Enterprises. All rights reserved.
    </div>
  </div>
</footer>
