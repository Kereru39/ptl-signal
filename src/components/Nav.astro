---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/episodes', label: 'Episodes' },
  { href: '/blog', label: 'Blog' },
  { href: '/earnings-analyzer', label: 'Earnings Analyzer' },
  { href: '/about', label: 'About' },
];
---

<nav class="border-b border-white/10 bg-navy/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex flex-col">
      <span class="font-mono font-bold text-xl tracking-tight">
        <span class="text-accent">PTL</span> Signal
      </span>
      <span class="text-gray-400 text-xs hidden sm:block">Cutting through the noise — AI, markets, and the signals that matter</span>
    </a>

    <!-- Mobile menu button -->
    <button id="menu-toggle" class="md:hidden text-white" aria-label="Toggle menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {links.map(link => (
        <a
          href={link.href}
          class={`text-sm transition-colors hover:text-accent ${
            currentPath === link.href ? 'text-accent font-semibold' : 'text-gray-300'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 px-4 pb-4">
    {links.map(link => (
      <a
        href={link.href}
        class={`block py-2 text-sm transition-colors hover:text-accent ${
          currentPath === link.href ? 'text-accent font-semibold' : 'text-gray-300'
        }`}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  document.getElementById('menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
