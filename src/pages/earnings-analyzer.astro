---
import Base from '../layouts/Base.astro';

const features = [
  {
    icon: "⚡",
    title: "Instant Analysis",
    description: "Paste any financial document — earnings transcript, annual report, Fed minutes, analyst note — and get key insights in under 60 seconds."
  },
  {
    icon: "📊",
    title: "Sentiment Detection",
    description: "AI-powered sentiment analysis catches what the numbers don't — management confidence, hedging language, policy signals, and red flags across any source."
  },
  {
    icon: "🎯",
    title: "Signal Extraction",
    description: "Key themes, risks, and opportunities pulled out and summarised automatically — whether you're reading a CEO letter, a macro report, or a central bank statement."
  },
  {
    icon: "🔔",
    title: "Cross-Source Intelligence",
    description: "Connect dots across multiple document types. Compare what a CEO says in an earnings call against what analysts write and what the Fed is signalling."
  }
];
---

<Base title="Financial Document Analyzer" description="AI-powered analysis of any financial document. Get the signals that matter in seconds.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24">
    <div class="absolute inset-0 opacity-5"
      style="background-image: radial-gradient(circle at 50% 50%, rgba(0,212,170,0.4) 0%, transparent 50%);">
    </div>

    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <div class="inline-block mb-6 px-4 py-1 border border-accent/30 rounded-full">
        <span class="font-mono text-accent text-sm">// early access</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
        Financial Document<br/><span class="text-accent">Analyzer</span>
      </h1>

      <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-6">
        AI-powered analysis of <em>any</em> financial document — not just earnings calls.
      </p>

      <p class="text-base text-gray-400 max-w-2xl mx-auto mb-10">
        Earnings transcripts, annual reports, Fed minutes, analyst reports, CEO letters, investor newsletters, macro commentary — paste it in and get the signals that matter in seconds, not hours.
      </p>

      <a
        href="https://www.earningscallanalyzer.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent text-navy font-bold px-10 py-4 rounded-lg hover:bg-accent-dark transition-colors text-lg"
      >
        Get Free Access — Founding Member &rarr;
      </a>
    </div>
  </section>

  <!-- Features -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid md:grid-cols-2 gap-6">
      {features.map(feature => (
        <div class="bg-navy-light border border-white/10 rounded-xl p-6 hover:border-accent/20 transition-colors">
          <span class="text-3xl">{feature.icon}</span>
          <h3 class="text-lg font-semibold mt-3">{feature.title}</h3>
          <p class="text-gray-400 text-sm mt-2">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- How it works -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold text-center mb-12">
      <span class="font-mono text-accent">//</span> How It Works
    </h2>
    <div class="grid md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="w-12 h-12 mx-auto rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center font-mono text-accent font-bold">1</div>
        <h3 class="font-semibold mt-4">Paste Any Document</h3>
        <p class="text-gray-400 text-sm mt-2">Paste text from any financial source — earnings call, annual report, Fed statement, analyst note, investor letter, or financial blog post.</p>
      </div>
      <div>
        <div class="w-12 h-12 mx-auto rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center font-mono text-accent font-bold">2</div>
        <h3 class="font-semibold mt-4">AI Analysis</h3>
        <p class="text-gray-400 text-sm mt-2">Our AI extracts key themes, sentiment, risks, metrics, and forward signals — tailored to the document type.</p>
      </div>
      <div>
        <div class="w-12 h-12 mx-auto rounded-full bg-accent/10 border border-accent/30 flex items-center justify-center font-mono text-accent font-bold">3</div>
        <h3 class="font-semibold mt-4">Get Signals</h3>
        <p class="text-gray-400 text-sm mt-2">Receive a clear, actionable summary with the signals that matter — the kind of intelligence previously reserved for professionals.</p>
      </div>
    </div>
  </section>
</Base>
