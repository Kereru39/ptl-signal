---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { videoIds } from '../data/episodes.js';

// Always shows the 3 most recent episodes — just add new ones to src/data/episodes.js
const featuredVideoIds = videoIds.slice(0, 3);

const blogPosts = [
  {
    title: "The Exponential Future: Abundance vs. Politics — Friedberg & Williamson on Humanity's Next Chapter",
    excerpt: "David Friedberg argues exponential convergence of AI, robotics, fusion, and biotech is transforming humanity — but warns that fear-based politics and wealth redistribution could sabotage everything.",
    date: "24/04/2026",
    tag: "AI",
    slug: "friedberg-williamson-exponential-abundance",
    image: "/blog/ptl-friedberg-williamson-exponential-tech.webp"
  },
  {
    title: "The Compute Crisis: Why Structural Semiconductor Shortages Mean Bitcoin Becomes Infrastructure, Not Speculation",
    excerpt: "Jordi Visser and Anthony Pompliano on AI inflation, supply-driven economics, and why the software abundance cycle is over. A regime shift that rewrites the playbook.",
    date: "19/04/2026",
    tag: "Macro",
    slug: "visser-pompliano-compute-crisis-bitcoin",
    image: "/blog/ptl-visser-pompliano-compute-scarcity.webp"
  },
  {
    title: "AI Doesn't Take Your Job—It Makes You the CEO. But Only Within Trusted Tribes",
    excerpt: "Balaji Srinivasan on why the internet is becoming like the Chinese internet, and what that means for work, privacy, and the future of AI collaboration.",
    date: "19/04/2026",
    tag: "AI",
    slug: "balaji-ai-trusted-tribes-ceo",
    image: "/blog/ptl-balaji-ai-trusted-tribes.png"
  },
  {
    title: "The Fiscal Trap: James Lavish on Why Bitcoin Is the Only Rational Exit From a Debasing Dollar",
    excerpt: "James Lavish — 25 years on Wall Street, COO of a $26 billion fund — argues the U.S. fiscal position is mathematically terminal. Here's why Bitcoin is the only rational exit.",
    date: "18/04/2026",
    tag: "Bitcoin",
    slug: "james-lavish-fiscal-trap-bitcoin-exit",
    image: "/blog/ptl-lavish-fiscal-dominance-bitcoin-exit.webp"
  },
  {
    title: "PTL Signal: Simon Dixon on Government Capture, Bitcoin, and Individual Sovereignty",
    excerpt: "Simon Dixon argues governments are fully captured by the financial industrial complex — and that self-custodied Bitcoin is the only real exit. Here's what landed.",
    date: "18/04/2026",
    tag: "Bitcoin",
    slug: "simon-dixon-bitcoin-sovereignty",
    image: "/blog/ptl-signal-bitcoin-sovereignty.png"
  },
  {
    title: "Tesla's Distributed Brain: Why FSD 14.3 Is Just the Beginning of a Planetary-Scale AI Network",
    excerpt: "FSD 14.3 isn't just another update. Tesla analyst Cern Basher explains why it marks the beginning of a planetary-scale distributed AI network spanning vehicles, robots, and space.",
    date: "13/04/2026",
    tag: "AI",
    slug: "tesla-distributed-brain-fsd-robotaxi",
    image: "/blog/tesla-distributed-brain-fsd-robotaxi.png"
  },
  {
    title: "The Dozen Doublings: Why Salim Ismail Says We're Choosing Between Star Trek and Mad Max",
    excerpt: "A dozen technologies are simultaneously doubling in capability while costs collapse toward zero. Salim Ismail argues this forces a civilizational choice: Star Trek or Mad Max.",
    date: "10/04/2026",
    tag: "AI",
    slug: "dozen-doublings-salim-ismail-star-trek-mad-max",
    image: "/blog/star-trek-mad-max-exponential-future.png"
  },
  {
    title: "The Unwind: Why Jordi Visser Says We're in a Stagflationary Bear Market",
    excerpt: "Jordi Visser isn't predicting a normal cyclical correction. He's arguing we've entered a stagflationary regime where Fed policy paralysis, AI disruption, and a 17-year credit unwind are converging — and traditional portfolios are failing.",
    date: "10/04/2026",
    tag: "Macro",
    slug: "stagflation-bear-market-ai-credit-unwind",
    image: "/blog/stagflation-credit-ai-unwind.png"
  },
  {
    title: "The Fed's Trap: Why Jordi Visser Says Bitcoin Wins When Policy Fails",
    excerpt: "Jordi Visser argues the Federal Reserve has lost the ability to fight inflation — trapped by debt levels that make the 1970s look like a golden age of fiscal discipline. Here's what that means for Bitcoin.",
    date: "05/04/2026",
    tag: "Macro",
    slug: "fed-trap-bitcoin-policy-fails",
    image: "/blog/fed-trap-bitcoin-ai-regime.png"
  },
  {
    title: "The Regime Shift Nobody's Talking About: Why Jordi Visser Says We've Left the QE Era for Good",
    excerpt: "Jordi Visser isn't predicting a recession. He's arguing something far more consequential: we've permanently exited the QE era, and most investors haven't adjusted because they don't realise the game has changed.",
    date: "29/03/2026",
    tag: "Macro",
    slug: "jordi-visser-regime-shift-qe-era",
    image: "/blog/visser-regime-shift-bitcoin-commodities.png"
  },
  {
    title: "The Terrafab Gambit: When 50x Compute Meets the End of Human Driving",
    excerpt: "Peter Diamandis, Dave Blundin, Alex Wiesner-Gross, and Salim Ismail unpack Elon's 1-terawatt compute play, the death of human driving, terminal value collapse, and machines that design machines.",
    date: "28/03/2026",
    tag: "AI",
    slug: "terrafab-gambit-exponential-future",
    image: "/blog/moonshots-exponential-future-mar2026.png"
  },
  {
    title: "Physical AI Is Coming To Healthcare — And It's Closer Than You Think",
    excerpt: "Humanoid robots are moving from factory floors into hospitals and aged care. The WHO projects a 10–15 million healthcare worker shortage by 2030. Here's why physical AI is the only answer that scales.",
    date: "28/03/2026",
    tag: "AI",
    slug: "robots-in-healthcare",
    image: "/blog/robots-in-healthcare.png"
  },
  {
    title: "Why Oil Is Screaming 'Buy Bitcoin' — And the Smart Money Is Listening",
    excerpt: "Oil broke down when every conventional analyst had $120+ penciled in. Stablecoins are flipping the payment infrastructure. AI agents are about to transact trillions on crypto rails.",
    date: "27/03/2026",
    tag: "Macro",
    slug: "oil-screaming-buy-bitcoin",
    image: "/blog/ptl-crypto-panel-mar26.png"
  },
  {
    title: "Why Wall Street's Frozen While the Market Burns",
    excerpt: "The S&P broke its 200-day moving average. Credit is deteriorating. Analysts are paralysed by tariff PTSD. Jordi Visser explains what's really happening — and how to position.",
    date: "24/03/2026",
    tag: "Macro",
    slug: "why-wall-street-frozen-market-burns",
    image: "/blog/stagflation-jordi-visser.jpg"
  },
  {
    title: "Stagflation 2.0: Why Jordi Visser Thinks This Is the 1970s With an AI Twist",
    excerpt: "Silver up 60%. Oil up 60%. DRAM up 500%. Jordi Visser sees a multi-year commodity supercycle colliding with AI deflation — and Bitcoin in the middle of it all.",
    date: "23/03/2026",
    tag: "Macro",
    slug: "stagflation-jordi-visser-1970s-bitcoin",
    image: "/blog/stagflation-jordi-visser.jpg"
  },
  {
    title: "The Humanoid Robot Inflection Point: Why This Is Happening Faster Than Anyone Thinks",
    excerpt: "Humanoid robots are no longer a future concept. BMW has them on production lines. Tesla is converting factories to build them at scale.",
    date: "20/03/2026",
    tag: "AI",
    slug: "humanoid-robot-inflection-point",
    image: "/blog/humanoid-robots.jpg"
  },
  {
    title: "Jordi Visser's Turbulence Model and Why the Next Rally Starts in Private Credit",
    excerpt: "Jordi Visser has identified the exact mechanism that could trigger Bitcoin's next major supercycle — hiding in a place most crypto investors aren't looking.",
    date: "20/03/2026",
    tag: "Macro",
    slug: "jordi-visser-turbulence-model"
  }
];
---

<Base title="Home">
  <Hero />

  <!-- Featured Episodes -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="flex items-center justify-between mb-10">
      <div>
        <span class="font-mono text-accent text-sm">// latest episodes</span>
        <h2 class="text-3xl font-bold mt-1">Latest Episodes</h2>
      </div>
      <a href="/episodes" class="text-accent text-sm font-mono hover:underline">View all &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {featuredVideoIds.map(id => (
        <div class="rounded-xl overflow-hidden border border-white/10 hover:border-accent/30 transition-colors aspect-video shadow-[0_0_20px_rgba(0,212,170,0.05)]">
          <iframe
            src={`https://www.youtube.com/embed/${id}?rel=0`}
            class="w-full h-full"
            style="border:0;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      ))}
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="flex items-center justify-between mb-10">
      <div>
        <span class="font-mono text-accent text-sm">// latest posts</span>
        <h2 class="text-3xl font-bold mt-1">Latest Posts</h2>
      </div>
      <a href="/blog" class="text-accent text-sm font-mono hover:underline">View all &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {blogPosts.map(post => (
        <BlogCard {...post} />
      ))}
    </div>
  </section>

  <!-- Newsletter Signup -->
  <NewsletterSignup variant="homepage" />

  <!-- Earnings Analyzer Promo -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="relative bg-navy-light border border-accent/20 rounded-2xl p-10 md:p-14 overflow-hidden">
      <!-- Background glows -->
      <div class="absolute top-0 right-0 w-80 h-80 bg-accent/8 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>

      <div class="relative">
        <span class="font-mono text-accent text-sm">// new tool</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Financial Document Analyzer</h2>
        <p class="text-gray-300 max-w-xl mb-8 text-lg leading-relaxed">
          Paste any financial document — earnings call transcripts, annual reports, Fed minutes, analyst reports, CEO letters, investor presentations — and get institutional-grade AI analysis in seconds. Free for founding members.
        </p>
        <a href="/earnings-analyzer" class="inline-block bg-accent text-navy font-bold px-8 py-4 rounded-lg hover:bg-accent-dark transition-colors text-lg">
          Get Free Access — Founding Member
        </a>
      </div>
    </div>
  </section>
</Base>
