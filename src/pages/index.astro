---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import BlogCard from '../components/BlogCard.astro';

const featuredEpisodes = [
  {
    title: "AI Agents Are About to Change Everything",
    videoId: "dQw4w9WgXcQ",
    description: "We break down why 2026 is the year AI agents go mainstream — and what it means for investors and builders.",
    date: "28/02/2026"
  },
  {
    title: "Bitcoin's Next Move: On-Chain Signals",
    videoId: "dQw4w9WgXcQ",
    description: "Analysing the on-chain data and macro signals pointing to Bitcoin's next major trend.",
    date: "21/02/2026"
  },
  {
    title: "NVIDIA Earnings Deep Dive",
    videoId: "dQw4w9WgXcQ",
    description: "Our Earnings Call Analyzer breaks down NVIDIA's latest results. Here's what the market missed.",
    date: "14/02/2026"
  }
];

const blogPosts = [
  {
    title: "Why I Built an AI Earnings Call Analyzer",
    excerpt: "Most investors don't have time to read 50-page transcripts. So I built a tool that does it in seconds — here's the story.",
    date: "01/03/2026",
    tag: "AI",
    slug: "why-i-built-earnings-analyzer"
  },
  {
    title: "5 AI Tools Every Investor Should Know About",
    excerpt: "From sentiment analysis to automated financial modelling, these tools are changing how smart money operates.",
    date: "22/02/2026",
    tag: "Tools",
    slug: "5-ai-tools-for-investors"
  },
  {
    title: "The Signal vs The Noise: Crypto Edition",
    excerpt: "How to filter real market signals from social media hype. A framework for clearer thinking in volatile markets.",
    date: "15/02/2026",
    tag: "Crypto",
    slug: "signal-vs-noise-crypto"
  }
];
---

<Base title="Home">
  <Hero />

  <!-- Featured Episodes -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">
        <span class="font-mono text-accent">//</span> Latest Episodes
      </h2>
      <a href="/episodes" class="text-accent text-sm font-mono hover:underline">View all &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {featuredEpisodes.map(ep => (
        <EpisodeCard {...ep} />
      ))}
    </div>
  </section>

  <!-- Blog Preview -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">
        <span class="font-mono text-accent">//</span> Latest Posts
      </h2>
      <a href="/blog" class="text-accent text-sm font-mono hover:underline">View all &rarr;</a>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {blogPosts.map(post => (
        <BlogCard {...post} />
      ))}
    </div>
  </section>

  <!-- Earnings Analyzer Promo -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="relative bg-navy-light border border-accent/20 rounded-2xl p-8 md:p-12 overflow-hidden">
      <!-- Background glow -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>

      <div class="relative">
        <span class="font-mono text-accent text-sm">// new tool</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">Earnings Call Analyzer</h2>
        <p class="text-gray-300 max-w-xl mb-6 text-lg">
          AI-powered analysis of earnings call transcripts. Get the signals that matter in seconds, not hours.
        </p>
        <a href="/earnings-analyzer" class="inline-block bg-accent text-navy font-semibold px-8 py-3 rounded-lg hover:bg-accent-dark transition-colors">
          Get Early Access
        </a>
      </div>
    </div>
  </section>
</Base>
