---
import Base from '../layouts/Base.astro';
import BlogCard from '../components/BlogCard.astro';

const allPosts = await Astro.glob('./blog/*.astro');
const posts = allPosts
  .filter(p => p.frontmatter)
  .map(p => p.frontmatter)
  .sort((a, b) => new Date(b.date) - new Date(a.date));

const formatDate = (iso) => {
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
};
---

<Base title="Blog">
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="mb-10">
      <span class="font-mono text-accent text-sm">// blog</span>
      <h1 class="text-4xl font-bold mt-2">Blog</h1>
      <p class="text-gray-400 mt-2">Deep dives, analysis, and insights on AI, markets, and crypto.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {posts.map(post => (
        <BlogCard
          title={post.title}
          excerpt={post.description}
          date={formatDate(post.date)}
          tag={post.tags[0]}
          slug={post.slug}
          image={post.image}
        />
      ))}
    </div>
  </section>
</Base>
