---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;   // relative path e.g. /blog/foo.jpg — will be made absolute for OG tags
  article?: {       // if provided, renders Article JSON-LD structured data
    datePublished: string;
    headline: string;
  };
}

const {
  title,
  description = 'AI, markets, and the signals that matter.',
  image,
  article,
} = Astro.props;

const siteUrl = 'https://ptlsignal.com';
const pageTitle = `${title} | PTL Signal`;
const canonicalUrl = Astro.url.href;
const ogImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${image}`)
  : `${siteUrl}/lisa-tamati.jpg`;

const jsonLd = article
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: article.headline,
      description: description,
      image: ogImage,
      author: {
        '@type': 'Person',
        name: 'Lisa Tamati',
        url: 'https://www.lisatamati.com',
      },
      publisher: {
        '@type': 'Organization',
        name: 'PTL Signal',
        url: siteUrl,
      },
      datePublished: article.datePublished,
      mainEntityOfPage: canonicalUrl,
    })
  : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="PTL Signal" />
    {article && <meta property="article:published_time" content={article.datePublished} />}
    {article && <meta property="article:author" content="Lisa Tamati" />}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD structured data (blog posts only) -->
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
